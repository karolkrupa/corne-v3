#include "print.h"
#include QMK_KEYBOARD_H
#include "keycode.h"

oled_rotation_t oled_init_user(oled_rotation_t rotation) {
    if(is_keyboard_master()) {
        return OLED_ROTATION_270;
    }
    return OLED_ROTATION_0;
}

void render_space(void) {
    oled_write_P(PSTR("     "), false);
}

/* KEYBOARD PET START */

/* settings */
#    define MIN_WALK_SPEED      10
#    define MIN_RUN_SPEED       40

/* advanced settings */
#    define ANIM_FRAME_DURATION 200  // how long each frame lasts in ms
#    define ANIM_SIZE           96   // number of bytes in array. If you change sprites, minimize for adequate firmware size. max is 1024

#    define CAT_IDLE_FRAMES 5
#    define CAT_IDLE_SPEED 20  // below this wpm value your animation will idle

// #define PREP_FRAMES 1 // uncomment if >1

#    define CAT_TAP_FRAMES 2
#    define CAT_TAP_SPEED 40  // above this wpm value typing animation to trigger

#    define CAT_ANIM_FRAME_DURATION 200  // how long each frame lasts in ms
// #define SLEEP_TIMER 60000 // should sleep after this period of 0 wpm, needs fixing
#    define CAT_ANIM_SIZE 636  // number of bytes in array, minimize for adequate firmware size, max is 1024

/* timers */
// static uint16_t key_timer; // timer to track the last keyboard activity
uint32_t anim_timer = 0;
uint32_t anim_sleep = 0;

/* current frame */
uint8_t current_frame = 0;

/* status variables */
int   current_wpm = 0;
led_t led_usb_state;

bool isSneaking = false;
bool isBarking = false;
bool isJumping  = false;
bool showedJump = true;

