    };

    // assumes 1 frame prep stage
    void animation_phase(void) {
        if (get_current_wpm() <= CAT_IDLE_SPEED) {
            cat_current_idle_frame = (cat_current_idle_frame + 1) % CAT_IDLE_FRAMES;
            oled_write_raw_P(idle[abs((CAT_IDLE_FRAMES - 1) - cat_current_idle_frame)], CAT_ANIM_SIZE);
        }
        if (get_current_wpm() > CAT_IDLE_SPEED && get_current_wpm() < CAT_TAP_SPEED) {
            // oled_write_raw_P(prep[abs((PREP_FRAMES-1)-current_prep_frame)], ANIM_SIZE); // uncomment if IDLE_FRAMES >1
            oled_write_raw_P(prep[0], CAT_ANIM_SIZE);  // remove if IDLE_FRAMES >1
        }
        if (get_current_wpm() >= CAT_TAP_SPEED) {
            cat_current_tap_frame = (cat_current_tap_frame + 1) % CAT_TAP_FRAMES;
            oled_write_raw_P(tap[abs((CAT_TAP_FRAMES - 1) - cat_current_tap_frame)], CAT_ANIM_SIZE);
        }
    }

#    if OLED_TIMEOUT > 0
    /* the animation prevents the normal timeout from occuring */
    if (last_input_activity_elapsed() > OLED_TIMEOUT && last_led_activity_elapsed() > OLED_TIMEOUT) {
        oled_off();
        return;
    } else {
        oled_on();
    }

#    endif

    if (timer_elapsed32(cat_anim_timer) > CAT_ANIM_FRAME_DURATION) {
        cat_anim_timer = timer_read32();
        animation_phase();
    }
}

char wpm_str[10];

bool oled_task_user(void) {
    // Renders the current keyboard state (layers and mods)
        /* KEYBOARD PET VARIABLES START */

    if (is_keyboard_master()) {
        current_wpm   = get_current_wpm();
        //led_usb_state = host_keyboard_led_state();

        oled_set_cursor(0, 1);
        render_luna(0, 1);
        oled_set_cursor(0, 5);
        render_layer_state();
        oled_set_cursor(0, 10);
        render_mod_status_gui_alt(get_mods()|get_oneshot_mods());
        render_mod_status_ctrl_shift(get_mods()|get_oneshot_mods());
    } else {
        render_cat();  // Renders a static logo

        oled_set_cursor(0, 0);                            // sets cursor to (row, column) using charactar spacing (5 rows on 128x32 screen, anything more will overflow back to the top)
        sprintf(wpm_str, "WPM:%03d", get_current_wpm());  // edit the string to change wwhat shows up, edit %03d to change how many digits show up
        oled_write(wpm_str, false);                       // writes wpm on top left corner of string
    }
    return false;
}

static uint16_t get_base_keycode(uint16_t keycode) {
    if (IS_QK_MOD_TAP(keycode)) {
        return QK_MOD_TAP_GET_TAP_KEYCODE(keycode);
    }
    if (IS_QK_LAYER_TAP(keycode)) {
        return QK_LAYER_TAP_GET_TAP_KEYCODE(keycode);
    }
    if (IS_QK_MODS(keycode)) {
        return keycode & 0xFF;
    }
    return keycode;
}

bool process_record_user(uint16_t keycode, keyrecord_t *record) {
#ifdef CONSOLE_ENABLE
    uprintf("KL: kc: %u, col: %2u, row: %2u, pressed: %u, time: %5u, int: %u, count: %u\n",
            keycode, record->event.key.col, record->event.key.row, record->event.pressed,
            record->event.time, record->tap.interrupted, record->tap.count);
#endif

    uint16_t kc = get_base_keycode(keycode);

    // Sprawdzenie, czy keycode ma Ctrl jako modifier (MT / LCTL_T / standardowy)
    bool has_ctrl = false;

    if (IS_QK_MODS(keycode)) {
        if (keycode & MOD_LCTL || keycode & MOD_RCTL) {
            has_ctrl = true;
        }
    } else if (IS_QK_MOD_TAP(keycode)) {
        if (QK_MOD_TAP_GET_MODS(keycode) & (MOD_LCTL | MOD_RCTL)) {
            has_ctrl = true;
        }
    }

    // Obsługa „sneaking” dla Ctrl lub Mod-Tap Ctrl
    if ((kc == KC_LCTL || kc == KC_RCTL || has_ctrl) && record->event.pressed) {
        isSneaking = true;
    } else if ((kc == KC_LCTL || kc == KC_RCTL || has_ctrl) && !record->event.pressed) {
        isSneaking = false;
    }

    // Obsługa Space
    if (kc == KC_SPC) {
        if (record->event.pressed) {
            isJumping  = true;
            showedJump = false;
        } else {
            isJumping = false;
        }
    }

    return true;
}

